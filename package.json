{
  "devDependencies": {
    "prettier": "latest",
    "turbo": "latest"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "name": "commerce-flow",
  "packageManager": "pnpm@8.15.8",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "test:e2e": "turbo test:e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v",
    "infra:logs": "docker compose logs -f",
    "test:infra:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:infra:down": "docker compose -f docker-compose.test.yml down -v",
    "test:api:integration": "pnpm test:infra:up && pnpm --filter @commerce-flow/api prisma:migrate:deploy:test && pnpm --filter @commerce-flow/api test:integration"
  },
  "version": "0.1.0"
}
